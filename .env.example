# === REQUIRED ===

# Your domain name (e.g. autods.example.com) — Caddy auto-provisions HTTPS.
# If you have no domain, use your server IP: http://1.2.3.4
# For IP-only (no HTTPS), also change docker-compose.prod.yml DOMAIN refs accordingly.
DOMAIN=autods.example.com

# Password users must enter to access the app (leave blank to disable the gate)
APP_ACCESS_PASSWORD=changeme

# Google Gemini API key for AI-written report summaries (free tier available at aistudio.google.com)
# Leave blank to use template-based summaries instead
GOOGLE_API_KEY=


# === OPTIONAL TUNING ===
OPTUNA_N_TRIALS=30
OPTUNA_TIMEOUT_S=180
FORECAST_PERIODS=30
ARTIFACT_RETENTION_DAYS=30
SHAP_SAMPLE_SIZE=200
