# Copy to .env and fill in. The app works with no key — narrative text falls back to templates.

ENV=development

# If set, the frontend must send this exact value in an X-App-Password header
# for every /api/v1/* request. Leave empty for unauthenticated local dev.
APP_ACCESS_PASSWORD=

# Get a free key at https://aistudio.google.com/apikey
LLM_PROVIDER=gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

DATABASE_URL=sqlite+aiosqlite:///./data/autods.db
CORS_ORIGINS=["http://localhost:3000"]

MAX_UPLOAD_MB=200
MAX_ROWS=500000

CV_FOLDS=5
RANDOM_STATE=42
TUNING_N_ITER=8
SHAP_SAMPLE_SIZE=200
